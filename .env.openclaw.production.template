# Wink NextChat x OpenClaw production deployment template
# Copy to .env.production on your server and replace placeholders.

# Optional access control for the web UI
CODE=
HIDE_USER_API_KEY=0
DISABLE_FAST_LINK=1
ENABLE_MCP=false

OPENAI_API_KEY=
CUSTOM_MODELS=
DEFAULT_MODEL=

# OpenClaw bridge
OPENCLAW_ENABLED=1
OPENCLAW_BRIDGE_URL=/api/openclaw

# Your OpenClaw gateway reachable from the Next.js server.
# Examples:
# - Local development: http://127.0.0.1:18789
# - Private network / Tailscale / reverse proxy: https://your-openclaw-host.example.com
OPENCLAW_GATEWAY_URL=https://your-openclaw-gateway.example.com

# Gateway token from ~/.openclaw/openclaw.json -> gateway.auth.token
OPENCLAW_AUTH_TOKEN=replace-with-your-openclaw-gateway-token

# channels.nextchat.sharedSecret from ~/.openclaw/openclaw.json
OPENCLAW_SHARED_SECRET=replace-with-your-nextchat-shared-secret

# Fallback agent for new sessions
OPENCLAW_DEFAULT_AGENT_ID=main

# OpenClaw UI users. Keep real usernames and passwords in server env only.
# No accounts are hard-coded in source code.
# OPENCLAW_AUTH_USERS=[{"username":"admin","password":"...","agents":["*"]},{"username":"tarot","password":"...","agents":["tarot"]},{"username":"chat","password":"...","agents":["chat"]}]

# Public URL of the deployed NextChat site
NEXTCHAT_PUBLIC_BASE_URL=https://your-chat-domain.example.com

# Server-side uploaded files will be stored here
NEXTCHAT_UPLOAD_DIR=/var/lib/wink-nextchat/uploads

# Max upload size in bytes. 20MB by default.
NEXTCHAT_UPLOAD_MAX_BYTES=20971520
